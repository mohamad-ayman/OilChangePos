# Optional. Leave unset or empty for local dev: the Vite dev server proxies `/api` to
# https://localhost:7099 (see vite.config.ts). Match OilChangePOS.API launchSettings.
#
# For production builds (static files on another host), set the public API origin:
# VITE_API_BASE_URL=https://your-server.example.com

VITE_API_BASE_URL=

# Set to true only for local UI work without the API (mock login in shared/api/auth.api.ts).
# VITE_USE_AUTH_MOCK=true

# Optional mock for inventory API (`shared/api/inventory.api.ts`).
# When true, reports also stay on mocks (see `VITE_REPORTS_MOCK` in `shared/api/reports.api.ts`).
# VITE_INVENTORY_MOCK=true

# Force mock reports only (inventory can still call the real API).
# VITE_REPORTS_MOCK=true

# POS uses the same contract as WinForms: POST /api/Sales (CompleteSaleRequest).
# POS mock is enabled when VITE_POS_MOCK=true OR VITE_INVENTORY_MOCK=true.
# VITE_POS_MOCK=true
